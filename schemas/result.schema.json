{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bridge Result",
  "description": "公司与个人 OpenClaw 双向桥接任务结果回传格式",
  "type": "object",
  "required": ["task_id", "status", "completed_at"],
  "additionalProperties": false,
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^bridge-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{3}$"
    },
    "idempotency_key": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "enum": ["home", "company"]
    },
    "target": {
      "type": "string",
      "enum": ["any", "home", "company"]
    },
    "flow_version": {
      "type": "string",
      "enum": ["v1", "v2"]
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "failed",
        "blocked_auth",
        "blocked_permission",
        "needs_review",
        "cancelled"
      ]
    },
    "executor_site_assigned": {
      "type": "string",
      "enum": ["home", "company"]
    },
    "company_lane_assigned": {
      "type": "string",
      "enum": ["safe-auto", "sandbox-auto", "human-review", "unknown"]
    },
    "executor_reclassified": {
      "type": "boolean",
      "description": "执行侧是否重新分类了 lane"
    },
    "company_reclassified": {
      "type": "boolean",
      "description": "公司侧是否重新分类了 lane"
    },
    "reclassification_reason": {
      "type": "string",
      "description": "重新分类的原因"
    },
    "result": {
      "type": "object",
      "properties": {
        "summary": {
          "type": "string",
          "maxLength": 2000,
      "description": "脱敏摘要，默认上限 2000 字符"
        },
        "word_count": {
          "type": "integer"
        }
      }
    },
    "artifacts": {
      "type": "array",
      "description": "产物引用，仅返回 opaque artifact_id",
      "items": {
        "type": "object",
        "required": ["type", "artifact_id", "sensitivity"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["obsidian-note", "report", "log"]
          },
          "artifact_id": {
            "type": "string",
            "description": "opaque ID，不返回可直接访问的 URL"
          },
          "sensitivity": {
            "type": "string",
            "enum": ["internal-summary"]
          },
          "accessible": {
            "type": "boolean",
            "const": false,
      "description": "固定为 false，不返回可访问 URL"
          }
        }
      }
    },
    "failure_info": {
      "type": "object",
      "description": "失败时填写",
      "properties": {
        "failure_type": {
          "type": "string",
          "enum": [
            "blocked_auth",
            "blocked_permission",
            "network_timeout",
            "quota_exceeded",
            "unsafe_request",
            "invalid_payload",
            "duplicate_claim",
            "lease_expired",
            "review_required",
            "unknown"
          ]
        },
        "message": {
          "type": "string",
          "maxLength": 500
        },
        "recovery_hint": {
          "type": "string",
          "maxLength": 200,
          "description": "恢复建议，例如需要哪个 CLI 重新登录"
        }
      }
    },
    "executor": {
      "type": "string",
      "description": "执行者标识，例如 home-openclaw 或 company-openclaw"
    },
    "tool_trace_ref": {
      "type": "string",
      "description": "工具调用追踪引用"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
