{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bridge Task",
  "description": "公司与个人 OpenClaw 双向桥接任务单",
  "type": "object",
  "required": ["task_id", "idempotency_key", "source", "target", "title", "lane", "payload", "created_at"],
  "additionalProperties": false,
  "oneOf": [
    {
      "properties": {
        "source": { "const": "home" },
        "target": { "const": "company" }
      }
    },
    {
      "properties": {
        "source": { "const": "company" },
        "target": { "const": "home" }
      }
    }
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^bridge-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{3}$",
      "description": "格式: bridge-YYYY-MM-DD-NNN，例如 bridge-2026-03-23-001"
    },
    "idempotency_key": {
      "type": "string",
      "description": "幂等键，防止重复执行。格式: {task_id}-v{version}"
    },
    "source": {
      "type": "string",
      "enum": ["home", "company"],
      "description": "任务发起侧"
    },
    "target": {
      "type": "string",
      "enum": ["home", "company"],
      "description": "任务执行侧"
    },
    "flow_version": {
      "type": "string",
      "enum": ["v1", "v2"],
      "default": "v2"
    },
    "requester": {
      "type": "string",
      "default": "bridge-openclaw"
    },
    "title": {
      "type": "string",
      "maxLength": 200
    },
    "lane": {
      "type": "string",
      "enum": ["safe-auto"],
      "description": "默认只允许 safe-auto。执行侧有权重新分类"
    },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "default": "medium"
    },
    "task_type": {
      "type": "string",
      "enum": [
        "status-summary",
        "public-research",
        "daily-report",
        "obsidian-write",
        "state-sync"
      ],
      "description": "允许的任务类型白名单"
    },
    "policy_version": {
      "type": "string",
      "default": "v1"
    },
    "sensitivity": {
      "type": "string",
      "enum": ["low"],
      "default": "low",
      "description": "默认敏感等级为 low"
    },
    "payload": {
      "type": "object",
      "required": ["instruction"],
      "additionalProperties": false,
      "properties": {
        "instruction": {
          "type": "string",
          "maxLength": 1000,
          "description": "任务指令（自然语言）"
        },
        "allowed_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["read_status", "summarize", "write_obsidian", "fetch_public"]
          },
          "description": "允许的动作白名单"
        },
        "max_output_chars": {
          "type": "integer",
          "maximum": 2000,
          "default": 2000
        }
      }
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 60,
      "maximum": 3600,
      "default": 600
    },
    "retry_budget": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3,
      "default": 2
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "running",
        "success",
        "failed",
        "blocked_auth",
        "blocked_permission",
        "needs_review",
        "cancelled"
      ],
      "default": "pending"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "_claim": {
      "type": "object",
      "description": "任务领取信息，由执行侧填写",
      "properties": {
        "executor": { "type": "string" },
        "claimed_at": { "type": "string", "format": "date-time" },
        "lease_expires_at": { "type": "string", "format": "date-time" }
      }
    },
    "_company_decision": {
      "type": "object",
      "description": "公司侧风险重新分类结果",
      "properties": {
        "lane_assigned": {
          "type": "string",
          "enum": ["safe-auto", "sandbox-auto", "human-review"]
        },
        "reclassified": { "type": "boolean" },
        "reclassification_reason": { "type": "string" },
        "checked_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
