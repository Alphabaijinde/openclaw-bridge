# ============================================================
# OpenClaw 桥接层配置文件
# ============================================================
# 复制此文件为 bridge.env，填入实际值后使用
# 注意：bridge.env 不要提交到 git！
# ============================================================

# ------------------
# 基础路径配置
# ------------------
# BRIDGE_ROOT 由脚本自动检测，不要手动设置
# 其他路径使用相对路径（相对于 BRIDGE_ROOT）
BRIDGE_ROLE="home"
BRIDGE_DEFAULT_TARGET="any"

# ------------------
# Git 远程仓库配置
# ------------------
# 公司侧桥接仓库地址（GitHub/GitLab/私有 Git）
BRIDGE_GIT_REMOTE="git@github.com:YourOrg/openclaw-bridge.git"
# 分支
BRIDGE_GIT_BRANCH="main"
# SSH 密钥（公司侧专用，不使用个人密钥）
BRIDGE_SSH_KEY="/home/user/.ssh/bridge_deploy_key"
# 执行器标识（可选；留空则默认按 BRIDGE_ROLE 生成）
BRIDGE_EXECUTOR=""
# Git 用户（仅用于 commit）
BRIDGE_GIT_USER_NAME="Home OpenClaw Bridge"
BRIDGE_GIT_USER_EMAIL="bridge@home.local"

# ------------------
# 执行侧配置（公司）
# ------------------
COMPANY_OBSIDIAN_DIR="/path/to/company/obsidian"
COMPANY_VAULT_NAME="company-vault"

# 公司侧 OpenClaw 配置
COMPANY_OPENCLAW_CONFIG="/path/to/company/.openclaw/config.json"

# 公司侧允许执行的 task_type（白名单）
ALLOWED_TASK_TYPES="status-summary,public-research,daily-report,obsidian-write,state-sync,infra-setup"

# 公司侧允许的 allowed_actions（白名单）
ALLOWED_ACTIONS_DEFAULT="read_status,summarize,write_obsidian,fetch_public"

# Phase 1 固定值
MAX_OUTPUT_CHARS="2000"
POLICY_VERSION="v1"

# ------------------
# 主控侧配置（家里）
# ------------------
HOME_OBSIDIAN_DIR="/home/user/Obsidian_Docs/work_jszr_linux"
HOME_OPENCLAW_CONFIG="/home/user/.openclaw/config.json"

# ------------------
# 飞书通知配置
# ------------------
FEISHU_WEBHOOK_URL="https://open.feishu.cn/open-apis/bot/v2/hook/XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX"
FEISHU_BOT_SECRET="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# 通知级别: info, warning, error
NOTIFY_ON_STATUS="success,failed,needs_review,blocked_auth"

# ------------------
# 执行器配置
# ------------------
# 执行超时（秒）
TASK_EXEC_TIMEOUT="600"

# Lease 过期时间（秒），超过后任务可被重新领取
TASK_LEASE_TTL="600"

# 重试次数
DEFAULT_RETRY_BUDGET="2"

# ------------------
# 日志配置
# ------------------
LOG_LEVEL="info"
LOG_FILE="${BRIDGE_LOGS_DIR}/bridge-$(date '+%Y-%m-%d').log"

# ------------------
# 安全配置
# ------------------
# 不允许跨边界的内容（正则，匹配即拒绝）
FORBIDDEN_PATTERNS="(\.env|OAuth|cookie|token|secret|credential|/etc/passwd|~/.ssh/)"

# Phase 1 敏感等级上限（L2 = low = 允许）
MAX_SENSITIVITY_LEVEL="L2"
